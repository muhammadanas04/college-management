# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/.turbo/

# production
/build

# misc & OS
.DS_Store
Thumbs.db
*.pem

# debug & logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (ignore all secrets, allow example files for repo docs)
.env*
!.env.example
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor & IDE configs
.obsidian/
.vscode/
.idea/
